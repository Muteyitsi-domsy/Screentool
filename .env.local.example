# ─── Supabase ────────────────────────────────────────────────────────────────
# From: supabase.com → Project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Lemon Squeezy ───────────────────────────────────────────────────────────
# Store slug: the subdomain of your LS store URL
# e.g. if your store is "myapp.lemonsqueezy.com" → VITE_LS_STORE_SLUG=myapp
VITE_LS_STORE_SLUG=

# Variant UUIDs from: Lemon Squeezy → Store → Products → [your product] → Variants
VITE_LS_VARIANT_SUBSCRIPTION=
VITE_LS_VARIANT_LIFETIME=

# ─── Supabase Edge Function secrets (set via CLI, NOT here) ──────────────────
# supabase secrets set LS_WEBHOOK_SECRET=xxx
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.
